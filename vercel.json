{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/paypal/create-order", "destination": "/api/create-order" },
    { "source": "/api/paypal/capture-order", "destination": "/api/capture-order" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
